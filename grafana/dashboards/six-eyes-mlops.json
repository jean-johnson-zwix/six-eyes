{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Grafana Cloud Metrics (Prometheus)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat",       "name": "Stat",        "version": "" },
    { "type": "panel", "id": "bargauge",   "name": "Bar gauge",   "version": "" },
    { "type": "panel", "id": "gauge",      "name": "Gauge",       "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "six-eyes MLOps — hype score, drift detection, data quality (weekly push from monitor.py)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "type": "text", "title": "", "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": { "content": "## six-eyes MLOps\nWeekly metrics pushed by `monitor.py` after each Evidently drift run.", "mode": "markdown" } },

    {
      "id": 1, "type": "stat", "title": "Mean Hype Score (latest)",
      "description": "Average predicted hype probability across papers in the current 30-day window.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue",  "value": null },
            { "color": "green", "value": 0.1 },
            { "color": "orange","value": 0.3 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "six_eyes_mean_hype_score", "legendFormat": "mean hype score", "refId": "A" }]
    },

    {
      "id": 2, "type": "stat", "title": "Papers in Window (latest)",
      "description": "Number of papers ingested in the last 30 days at time of last monitor run.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 2 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "six_eyes_current_papers_count", "legendFormat": "papers", "refId": "A" }]
    },

    {
      "id": 3, "type": "gauge", "title": "Drift Share (latest)",
      "description": "Fraction of features where Evidently detected drift vs the seed training distribution.",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 2 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 0.2 },
            { "color": "red",    "value": 0.5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "six_eyes_drift_share", "legendFormat": "drift share", "refId": "A" }]
    },

    {
      "id": 4, "type": "stat", "title": "Dataset Drift Detected",
      "description": "1 = Evidently flagged overall dataset drift; 0 = no drift.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 2 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No drift", "color": "green" }, "1": { "text": "DRIFT", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "six_eyes_drift_detected", "legendFormat": "drift detected", "refId": "A" }]
    },

    {
      "id": 5, "type": "timeseries", "title": "Mean Hype Score — Weekly Trend (req 6.2)",
      "description": "Predicted hype score mean over time. Sustained drop signals model degradation.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "fixed", "fixedColor": "#f5c842" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "six_eyes_mean_hype_score", "legendFormat": "mean hype score", "refId": "A" }]
    },

    {
      "id": 6, "type": "timeseries", "title": "Drift Share — Weekly Trend (req 6.3)",
      "description": "Fraction of features drifted over time. Rising trend = distribution shift.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "fixed", "fixedColor": "#e8513a" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow","value": 0.2 },
            { "color": "red",   "value": 0.5 }
          ]}
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "six_eyes_drift_share", "legendFormat": "drift share", "refId": "A" }]
    },

    {
      "id": 7, "type": "bargauge", "title": "Feature Drift Scores (latest, req 6.3)",
      "description": "Per-feature Evidently drift score from the latest monitor run. Higher = more drift vs training distribution.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "red",    "value": 0.3 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal",
        "displayMode": "gradient", "valueMode": "color", "showUnfilled": true },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sort_desc(six_eyes_feature_drift_score)", "legendFormat": "{{feature}}", "refId": "A",
        "instant": true }]
    },

    {
      "id": 8, "type": "timeseries", "title": "Top Feature Drift — Time Series (req 6.3)",
      "description": "Drift score per feature over time. Helps identify which features are driving distribution shift.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0,
          "custom": { "lineWidth": 1.5, "fillOpacity": 0, "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "right" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "topk(8, six_eyes_feature_drift_score)", "legendFormat": "{{feature}}", "refId": "A" }]
    },

    {
      "id": 9, "type": "timeseries", "title": "Current Window Paper Count (req 6.4 — data quality)",
      "description": "Number of live papers in the 30-day window per monitor run. Low values may indicate ingestion issues.",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#5a9e52" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "six_eyes_current_papers_count", "legendFormat": "papers in window", "refId": "A" }]
    }

  ],
  "refresh": "",
  "schemaVersion": 39,
  "tags": ["six-eyes", "mlops", "drift"],
  "templating": { "list": [] },
  "time": { "from": "now-90d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "six-eyes MLOps",
  "uid": "six-eyes-mlops-v1",
  "version": 1
}
