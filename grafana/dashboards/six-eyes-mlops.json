{
  "annotations": [],
  "description": "six-eyes MLOps — hype score, drift detection, data quality (weekly push from monitor.py)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "datasource": null,
      "options": {
        "content": "## six-eyes MLOps\nWeekly metrics pushed by `monitor.py` after each Evidently drift run.",
        "mode": "markdown"
      },
      "transformations": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Mean Hype Score (latest)",
      "description": "Average predicted hype probability across papers in the current 30-day window.",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "green",  "value": 0.1  },
              { "color": "orange", "value": 0.3  }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "transformations": [],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "last_over_time(six_eyes_mean_hype_score[14d])",
          "legendFormat": "mean hype score",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Papers in Window (latest)",
      "description": "Number of papers ingested in the last 30 days at time of last monitor run.",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 2 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "textMode": "auto"
      },
      "transformations": [],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "last_over_time(six_eyes_current_papers_count[14d])",
          "legendFormat": "papers",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Drift Share (latest)",
      "description": "Fraction of features where Evidently detected drift vs the seed training distribution.",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 2 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.2  },
              { "color": "red",    "value": 0.5  }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "transformations": [],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "last_over_time(six_eyes_drift_share[14d])",
          "legendFormat": "drift share",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Dataset Drift Detected",
      "description": "1 = Evidently flagged overall dataset drift; 0 = no drift.",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 2 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "No drift", "color": "green", "index": 0 },
                "1": { "text": "DRIFT",    "color": "red",   "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1    }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "transformations": [],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "last_over_time(six_eyes_drift_detected[14d])",
          "legendFormat": "drift detected",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Mean Hype Score — Weekly Trend (req 6.2)",
      "description": "Predicted hype score mean over time. Sustained drop signals model degradation.",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "#f5c842" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "transformations": [],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "six_eyes_mean_hype_score",
          "legendFormat": "mean hype score",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Drift Share — Weekly Trend (req 6.3)",
      "description": "Fraction of features drifted over time. Rising trend = distribution shift.",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "#e8513a" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.2  },
              { "color": "red",    "value": 0.5  }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "transformations": [],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "six_eyes_drift_share",
          "legendFormat": "drift share",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Feature Drift Scores (latest, req 6.3)",
      "description": "Per-feature Evidently drift score from the latest monitor run.",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.1  },
              { "color": "red",    "value": 0.3  }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "transformations": [],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "sort_desc(last_over_time(six_eyes_feature_drift_score[14d]))",
          "legendFormat": "{{feature}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Top Feature Drift — Time Series (req 6.3)",
      "description": "Drift score per feature over time. Helps identify which features drive distribution shift.",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 1.5, "fillOpacity": 0, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "right", "calcs": [] }
      },
      "transformations": [],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "topk(8, six_eyes_feature_drift_score)",
          "legendFormat": "{{feature}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Current Window Paper Count (req 6.4 — data quality)",
      "description": "Number of live papers in the 30-day window per monitor run. Low values may indicate ingestion issues.",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
