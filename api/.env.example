# api/.env.example
# Copy to api/.env and fill in real values (never commit .env).

# Required: PostgreSQL connection string for Supabase
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Required: Bearer token for API authentication (set the same value in dashboard)
API_KEY=your-secret-api-key

# Optional: HuggingFace base URL for model artifacts (fetched at startup if set)
MODEL_BASE_URL=https://huggingface.co/jeanjohnson/six-eyes-model/resolve/main/

# Optional: Local cache directory for model files (default: /tmp/model)
MODEL_DIR=/tmp/model

# Optional: HTTP listen port (default: 8080)
PORT=8080
